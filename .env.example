# ==============================================================
# BlixNex — Example environment contract (PLACEHOLDERS ONLY)
# --------------------------------------------------------------
# This file documents the SHAPE of configuration the platform
# expects. It contains no real secrets. Copy to `.env` locally
# and fill with your own values. `.env` is git-ignored.
#
# Every value below is a placeholder. Nothing here is live.
# ==============================================================

# ----- Core data / auth (Supabase) ----------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-only, never expose to client
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ----- AI / LLM providers -------------------------------------
# Provider keys are optional individually; the router uses whichever are present.
ANTHROPIC_API_KEY=your-anthropic-key-here              # Claude: research, vision-QA, drafting, site-editor
OPENROUTER_API_KEY=your-openrouter-key-here            # DeepSeek (primary HTML generation)
OPENAI_API_KEY=your-openai-key-here                    # embeddings + image generation
GEMINI_API_KEY=your-gemini-key-here                    # fallback provider
GROQ_API_KEY=your-groq-key-here                        # fallback provider

# ----- Render / worker pipeline -------------------------------
REDIS_URL=redis://localhost:6379                       # BullMQ broker + milestone pub/sub
RENDER_AGENT_DAEMON_URL=https://your-internal-daemon.example
RENDER_AGENT_DAEMON_TOKEN=your-daemon-shared-secret
RENDER_COMPOSER_MODE=                                  # unset = default daemon path | direct | template (canary)
CRAWL_SIDECAR_URL=https://your-internal-crawler.example
VISION_QA_GATE_ENABLED=false                           # feature flag (off by default)
RESEARCH_INTEL_ENABLED=false                           # feature flag (off by default)
QA_AUTO_REPAIR_ENABLED=true

# ----- Cost & budget caps (USD) -------------------------------
RENDER_MAX_COST_USD=5.00                               # hard per-render ceiling
RENDER_REPAIR_BUDGET_USD=1.50                          # bounded repair-pass budget
DAILY_LLM_COST_CAP_CENTS=50000                         # per-tenant daily LLM spend cap

# ----- Object storage / CDN (Cloudflare R2, S3 API) -----------
R2_ACCOUNT_ID=your-account-id-here
R2_ACCESS_KEY_ID=your-access-key-here
R2_SECRET_ACCESS_KEY=your-secret-key-here
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://your-cdn-host.example

# ----- Communications (voice / SMS / iMessage) ----------------
VOICE_AGENT_API_KEY=your-voice-provider-key-here
SMS_API_KEY=your-sms-provider-key-here
SMS_FALLBACK_API_KEY=your-imessage-provider-key-here

# ----- Email -------------------------------------------------
EMAIL_API_KEY=your-transactional-email-key-here
EMAIL_FROM=hello@your-domain.example

# ----- Payments ----------------------------------------------
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-signing-secret-here

# ----- Optional integrations ----------------------------------
GOOGLE_PLACES_API_KEY=your-places-key-here             # reputation / business-profile intel (optional)
WEB_PUSH_VAPID_PUBLIC_KEY=your-vapid-public-key-here
WEB_PUSH_VAPID_PRIVATE_KEY=your-vapid-private-key-here

# ----- App URLs / runtime -------------------------------------
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
