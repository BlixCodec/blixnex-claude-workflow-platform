# ─────────────────────────────────────────────────────────────
# Dependencies
# ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.pnpm-store/

# ─────────────────────────────────────────────────────────────
# Environment & secrets — NEVER commit real values.
# Only .env.example (placeholders) is tracked.
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key

# ─────────────────────────────────────────────────────────────
# Build output
# ─────────────────────────────────────────────────────────────
.next/
dist/
build/
out/

# ─────────────────────────────────────────────────────────────
# Caches, coverage, logs
# ─────────────────────────────────────────────────────────────
.cache/
coverage/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─────────────────────────────────────────────────────────────
# Deploy / platform artifacts
# ─────────────────────────────────────────────────────────────
.vercel/
.railway/

# ─────────────────────────────────────────────────────────────
# OS / editor
# ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/

# ─────────────────────────────────────────────────────────────
# Local-only overrides
# ─────────────────────────────────────────────────────────────
*.local
